generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  userId        String   @unique
  balance       Float    @default(0)
  kiboCash      Float    @default(0)
  isPremium     Boolean  @default(false)
  vipExpiresAt  DateTime?
  skills        Json     @default("{\"sorte\": 1, \"labia\": 1}")
  badges        String[]
  isBanned      Boolean  @default(false) // ADICIONE ESTA LINHA EXATAMENTE AQUI
}

model Transaction {
  id          String   @id @default(uuid())
  fromUserId  String   
  toUserId    String   
  amount      Float
  timestamp   DateTime @default(now())
}

model GuildConfig {
  id              String   @id @default(uuid())
  guildId         String   @unique
  wlActive        Boolean  @default(false)
  wlName          String?
  wlAvatar        String?
  wlWebhookUrl    String?
  casinoEnabled   Boolean  @default(true)
}