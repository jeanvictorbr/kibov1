generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  userId        String   @unique
  balance       Float    @default(0)
  bank          Float    @default(0)
  kiboCash      Float    @default(0)
  isPremium     Boolean  @default(false)
  vipExpiresAt  DateTime?
  skills        Json     @default("{\"sorte\": 1, \"labia\": 1}")
  badges        String[]
  isBanned      Boolean  @default(false)
  currentJob    String    @default("desempregado") // "onesto", "crime", "hacker"
  jobStartedAt  DateTime? // Data que iniciou o trabalho atual
  inventory     Inventory[]
  businesses    UserBusiness[]
}

model Transaction {
  id          String   @id @default(uuid())
  fromUserId  String   
  toUserId    String   
  amount      Float
  timestamp   DateTime @default(now())
}

model GuildConfig {
  id              String   @id @default(uuid())
  guildId         String   @unique
  wlActive        Boolean  @default(false)
  wlName          String?
  wlAvatar        String?
  wlWebhookUrl    String?
  casinoEnabled   Boolean  @default(true)
}

model Cooldown {
  id        String   @id @default(uuid())
  userId    String
  command   String   // 'executar', 'daily', 'mensal', etc
  expiresAt DateTime
  @@unique([userId, command])
}

model ShopItem {
  id          String @id @default(uuid())
  name        String @unique
  price       Int
  description String
  type        String // Ex: 'COSMETIC', 'BOOSTER', 'UTILITY'
}

model Inventory {
  id     String @id @default(uuid())
  userId String
  itemId String
  user   User   @relation(fields: [userId], references: [userId])
}

model UserBusiness {
  id            String   @id @default(uuid())
  userId        String
  businessId    String   
  lastCollected DateTime @default(now())
  forSalePrice  Float?   // NOVO: Preço de venda definido pelo jogador (nulo se não estiver à venda)
  user          User     @relation(fields: [userId], references: [userId])
}